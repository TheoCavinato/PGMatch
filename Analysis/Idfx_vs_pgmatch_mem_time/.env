IDS_TEST=$DATASET_FOLDER/ids_test.txt
MAPPING=$DATASET_FOLDER/mapping.tsv.gz
PGS_idfx_train=$DATASET_FOLDER/pgs.train.idfx.tsv.gz
PGS_idfx_test=$DATASET_FOLDER/pgs.test.idfx.tsv.gz
PHENO_idfx_train=$DATASET_FOLDER/pheno.train.idfx.tsv.gz
PHENO_idfx_test=$DATASET_FOLDER/pheno.test.idfx.tsv.gz
SUB_MAPPING=$DATASET_FOLDER/sub.trait_gwas_mapping.tsv
TRAIN_MODEL=$REAL_IDFX_FOLDER/train_model_phenos
TRAIN_MODEL_OUT=$REAL_IDFX_FOLDER/train_model_out_phenos

TEST_MODEL_OUT=$REAL_IDFX_FOLDER/test_model_out_phenos

TIME_IDFX_TEST=$TIME_FOLDER/n_train_$N_TRAIN.n_test_$N_TEST.n_pheno_$NBR_PHENO.idfx_test.$ITR.time
TIME_IDFX_TRAIN=$TIME_FOLDER/n_train_$N_TRAIN.n_test_$N_TEST.n_pheno_$NBR_PHENO.idfx_train.$ITR.time

#------------------------------------------------------------------------------#
# Step 4 - Make plots
