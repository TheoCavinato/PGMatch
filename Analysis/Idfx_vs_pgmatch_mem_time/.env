
#------------------------------------------------------------------------------#
# Paths
#------------------------------------------------------------------------------#

SCRATCH=/scratch/tcavinat/Phenotype_inference_attack/Idfx_vs_pgmatch_mem_time/
SHARED_DATA=/data/FAC/FBM/DBC/zkutalik/default_sensitive/tcavinat/Phenotype_inference_attack/Shared_data

#------------------------------------------------------------------------------#
# Tools
#------------------------------------------------------------------------------#
PGMATCH=/work/FAC/FBM/DBC/zkutalik/sgg_software/tcavinat/PGMatch
IDEFIX_GENERATION=/work/FAC/FBM/DBC/zkutalik/sgg_software/tcavinat/pgs_based_sample_mix-up_correction/src/generate-sample-couplings.R
IDEFIX_SWAP=/work/FAC/FBM/DBC/zkutalik/sgg_software/tcavinat/pgs_based_sample_mix-up_correction/src/sample-swap-prediction.R

#------------------------------------------------------------------------------#
# Create R2 files
#------------------------------------------------------------------------------#

PARAM_FOLDER=$SCRATCH/N_train_$N_TRAIN.N_test_$N_TEST.n_pheno_$NBR_PHENO/

#------------------------------------------------------------------------------#
# Step 1 - Create dataset
#------------------------------------------------------------------------------#

# input
VAR_EXPL_NO_CORR=/data/FAC/FBM/DBC/zkutalik/default_sensitive/tcavinat/Phenotype_inference_attack/Compute_variance_explained/variance_explained.many_inds.no_corr.tsv

# output
DATASET_FOLDER=$PARAM_FOLDER/Dataset/
PHENO_TRAIN=$DATASET_FOLDER/pheno.train.tsv.gz
PHENO_TEST=$DATASET_FOLDER/pheno.test.tsv.gz

PGS_TRAIN_H0=$DATASET_FOLDER/pgs.train.h0.tsv.gz
PGS_TEST_H0=$DATASET_FOLDER/pgs.test.h0.tsv.gz
PGS_TRAIN_H1=$DATASET_FOLDER/pgs.train.h1.tsv.gz
PGS_TEST_H1=$DATASET_FOLDER/pgs.test.h1.tsv.gz

#------------------------------------------------------------------------------#
# Step 2 - Apply your method
#------------------------------------------------------------------------------#

# output
TIME_FOLDER=$SCRATCH/Time_result
MY_METHOD_FOLDER=$PARAM_FOLDER/My_method_$ITR/
R2=$MY_METHOD_FOLDER/r2.tsv.gz
CE=$MY_METHOD_FOLDER/ce.tsv.gz
CG=$MY_METHOD_FOLDER/cg.tsv.gz
TRAIN_LLR_H1=$MY_METHOD_FOLDER/llr.train.h1.tsv.gz
TRAIN_LLR_H0=$MY_METHOD_FOLDER/llr.train.h0.tsv.gz

TEST_LLR_H0=$MY_METHOD_FOLDER/llr.test.h0.tsv.gz
TEST_LLR_H1=$MY_METHOD_FOLDER/llr.test.h1.tsv.gz

SUP_PROBAS_H0=$MY_METHOD_FOLDER/my_method.probas.h0.tsv.gz
SUP_PROBAS_H1=$MY_METHOD_FOLDER/my_method.probas.h1.tsv.gz

TIME_MY_METHOD=$TIME_FOLDER/n_train_$N_TRAIN.n_test_$N_TEST.n_pheno_$NBR_PHENO.pgmatch.$ITR.time

#------------------------------------------------------------------------------#
# Step 3 -Idfx
#------------------------------------------------------------------------------#

# input
COF=$SHARED_DATA/Covariates.txt.gz

# output
REAL_IDFX_FOLDER=$PARAM_FOLDER/Real_idfx_method_$ITR/
